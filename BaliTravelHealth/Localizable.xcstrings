        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Casa dolce casa. Ultimo passo, resta in forma."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "やっぱりお家。最後の仕上げ、元気でね。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "집이 최고. 마지막 단계, 컨디션 챙기기."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Heerlijk thuis. Laatste stap, blijf sterk."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Дома лучше. Последний шаг — береги себя."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
