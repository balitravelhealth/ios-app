    "Home sweet home. Last action. Stay robust." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "البيت بيتك. آخر شي. خلّيك قوي."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Endlich daheim. Letzter Schritt, bleib stark."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hogar dulce hogar. Último paso, cuídate."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Home sweet home. Dernière étape, reste en forme."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "घर जैसा कुछ नहीं। आख़िरी कदम, फिट रहो।"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rumah memang paling enak. Langkah terakhir, tetap fit ya."
          }
